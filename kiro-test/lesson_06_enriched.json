    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Esta palabra interrogativa pregunta por identidad. ¿Cómo dirías quién?"
    },
    {
      "lang": "silence",
      "ms": 4500
    },
    {
      "lang": "gr",
      "text": "τίς",
