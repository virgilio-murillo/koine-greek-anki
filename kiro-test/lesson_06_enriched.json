    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Esta palabra indica un lugar distante de mí. ¿Cómo dirías allí?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ἐκεῖ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Esta palabra pregunta por la ubicación de algo. ¿Cómo dirías dónde?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ποῦ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
