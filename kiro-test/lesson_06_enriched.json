    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Combina ποῦ que significa dónde, con ἐστιν que significa está. Pregunta dónde está."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ποῦ ἐστιν;",
