      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Pregunta por la identidad de alguien. ¿Cómo dirías quién es?"
    },
    {
      "lang": "silence",
      "ms": 4500
    },
    {
      "lang": "gr",
      "text": "τίς ἐστιν;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Indica presencia en lugar distante. ¿Cómo dirías está allí?"
    },
    {
      "lang": "silence",
      "ms": 4500
    },
    {
      "lang": "gr",
      "text": "ἐκεῖ ἐστιν",
