    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "El hombre preguntó cuántos panes tienen. La mujer respondió cinco panes y dos peces. Es la escena de la alimentación de los cinco mil."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
