    {
      "lang": "es",
      "text": "Μάθημα ἐννέα. Lección nueve. Hoy aprenderás los números del uno al diez en griego koiné. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Πόσους ἄρτους ἔχετε;",
