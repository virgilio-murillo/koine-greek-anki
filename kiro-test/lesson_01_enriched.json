    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "ἐγώ significa yo. Es la forma enfática del pronombre, como cuando en español dices yo mismo para hacer énfasis. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ἐγώ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "gr",
      "text": "ἐγώ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías no?"
