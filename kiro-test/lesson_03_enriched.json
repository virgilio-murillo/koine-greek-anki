  "segments": [
    {
      "lang": "es",
      "text": "Μάθημα τρία. Lección tres. Hoy aprenderás a decir de dónde eres y a preguntar a otros. Escucha esta conversación."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Χαῖρε! Πόθεν εἶ σύ;",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "ἐγώ εἰμι ἀπὸ Γαλιλαίας. Καὶ σύ;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "ἀπὸ Ἰερουσαλήμ.",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "El hombre preguntó de dónde es la mujer. Ella respondió que es de Galilea y le preguntó a él. Él es de Jerusalén."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías él?"
