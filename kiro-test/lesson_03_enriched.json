    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "πόθεν",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "ἀπό significa de o desde. Se usa para lugares geográficos. ἀπὸ Γαλιλαίας, de Galilea. Es como decir desde Galilea hasta aquí. Esta preposición siempre va antes del lugar. En gramática se llama preposición. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ἀπό",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "gr",
      "text": "ἀπό",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías eres?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "εἶ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "ἐστιν significa es. Es la tercera persona del verbo εἰμί. El patrón completo es εἰμί yo soy, εἶ tú eres, ἐστιν él o ella es. Cuando hablas sobre otra persona, usas ἐστιν. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ἐστιν",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "gr",
      "text": "ἐστιν",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías de, desde?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ἀπό",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías de dónde?"
