      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ἀπό",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Pregunta de dónde eres. Son dos palabras: πόθεν que significa de dónde, y εἶ que significa eres."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
