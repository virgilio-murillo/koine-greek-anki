      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Aprende a decir sí. En griego koiné, sí se dice ναί. Aparece en Mateo cinco treinta y siete. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ναί",
