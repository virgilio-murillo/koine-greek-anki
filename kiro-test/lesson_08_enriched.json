  "segments": [
    {
      "lang": "es",
      "text": "Μάθημα ὀκτώ. Lección ocho. Nota que el griego ahora suena un poco más rápido. Hoy aprenderás vocabulario del mercado: pan, agua, vino. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Θέλεις ἄρτον;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "ναί, θέλω ἄρτον καὶ ὕδωρ.",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Ἰδού. Λάβε.",
