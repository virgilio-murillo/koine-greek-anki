    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "Una vendedora ofrece pan. El hombre quiere pan y agua. Ella le dice toma. Él da gracias."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías vengan?"
