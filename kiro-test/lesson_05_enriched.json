      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías el masculino?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ὁ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "Cuando la cosa no es ni masculina ni femenina, usas τό que significa lo. Es como decir lo bueno, lo importante. A esto se le llama género neutro. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "τό",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
