{
  "lesson": 5,
  "segments": [
    {
      "lang": "es",
      "text": "Μάθημα πέντε. Lección cinco. Hoy aprenderás a decir el, la, lo, y a señalar personas y cosas. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Βλέπεις τὸν ἄνθρωπον ἐκεῖνον;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "ναί. Τίς ἐστιν;",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Οὗτός ἐστιν ὁ διδάσκαλος.",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "La mujer preguntó si ves a aquel hombre. El hombre preguntó quién es. Ella dijo que es el maestro."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías pero?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "δέ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías él es de Jerusalén?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "αὐτός ἐστιν ἀπὸ Ἰερουσαλήμ",
