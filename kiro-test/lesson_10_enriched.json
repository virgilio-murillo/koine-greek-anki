    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "πολύς",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "οὐδείς significa nadie. οὐδέν es la forma neutra: nada. οὐκ ἔχω οὐδέν, no tengo nada. La palabra empieza con οὐ que es la negación no, así que significa literalmente no uno, es decir, nadie. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "οὐδείς",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "gr",
      "text": "οὐδείς",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías poco?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ὀλίγος",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
