  "lesson": 10,
  "segments": [
    {
      "lang": "es",
      "text": "Μάθημα δέκα. Lección diez. Hoy aprenderás a decir tengo, no tengo, y a hablar de necesidades. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Ἔχεις ἄρτον;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Οὐκ ἔχω. Χρείαν ἔχω ἄρτου.",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Ἰδού, λάβε τοῦτον.",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "La mujer preguntó si tiene pan. El hombre no tiene. Tiene necesidad de pan. Ella le dice mira, toma este."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías tú?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "σύ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.85
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías el hombre está allí?"
