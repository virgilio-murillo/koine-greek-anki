    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "La mujer preguntó si ves a aquel hombre. El hombre preguntó quién es. Ella dijo que es el maestro."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
