    {
      "lang": "es",
      "text": "Μάθημα πέντε. Lección cinco. Hoy aprenderás a decir el, la, lo, y a señalar personas y cosas. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Βλέπεις τὸν ἄνθρωπον ἐκεῖνον;",
