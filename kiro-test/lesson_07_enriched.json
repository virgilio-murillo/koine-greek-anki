    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "Πόθεν εἶ σύ;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías no oigo?"
