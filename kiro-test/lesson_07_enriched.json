    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "οὐκ ἀκούω",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías mi nombre es María?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "Τὸ ὄνομά μου Μαρία",
