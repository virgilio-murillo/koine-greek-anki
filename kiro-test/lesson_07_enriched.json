{
  "lesson": 7,
  "segments": [
    {
      "lang": "es",
      "text": "Μάθημα ἑπτά. Lección siete. Esta es la última lección a velocidad lenta. Hoy aprenderás a decir ir, venir, y caminar. Escucha."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "Ποῦ πορεύῃ;",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Πορεύομαι εἰς τὸ ἱερόν.",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "Ἔρχου μετ᾽ ἐμοῦ.",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "gr",
      "text": "ναί, ἔρχομαι.",
      "voice": "el-GR-Chirp3-HD-Achird",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 400
    },
    {
      "lang": "silence",
      "ms": 600
    },
    {
      "lang": "es",
      "text": "La mujer preguntó a dónde va el hombre. Él va al templo. Ella le dijo ven conmigo, y él aceptó."
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "es",
      "text": "Antes de aprender palabras nuevas, repasemos."
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías palabra?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "λόγος",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías el hombre está allí?"
    },
    {
      "lang": "silence",
      "ms": 4000
    },
    {
      "lang": "gr",
      "text": "ὁ ἄνθρωπος ἐκεῖ ἐστιν",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías de dónde eres tú?"
