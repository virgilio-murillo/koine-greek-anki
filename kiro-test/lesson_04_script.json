      "text": "λέγω",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "ἀλλά también significa pero, pero es más fuerte, como sino. A diferencia de δέ, ἀλλά sí va al principio. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "ἀλλά",
      "voice": "el-GR-Chirp3-HD-Zephyr",
