      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 500
    },
    {
      "lang": "es",
      "text": "δέ significa pero o y. Es especial porque nunca va al principio de la frase. Siempre va en segundo lugar. Por ejemplo, ἐγὼ δέ significa pero yo. Escucha."
    },
    {
      "lang": "silence",
      "ms": 300
    },
    {
      "lang": "gr",
      "text": "δέ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "gr",
      "text": "δέ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 800
    },
    {
      "lang": "gr",
      "text": "ἐγὼ δέ",
      "voice": "el-GR-Chirp3-HD-Zephyr",
      "speed": 0.75
    },
    {
      "lang": "silence",
      "ms": 3500
    },
    {
      "lang": "es",
      "text": "¿Cómo dirías otra vez, de nuevo?"
